TEXT 736 -104 Left 2 !.model MYPMOS PMOS (Vto=-0.3 Kp=50m Cgso=1p Cgdo=1p)\n.model MYNMOS NMOS (Vto=0.3  Kp=100m Cgso=1p Cgdo=1p)
TEXT 736 -32 Left 2 !.tran 0 10u 5u 100p
TEXT 736 8 Left 2 !.param Iload=1 PnTSV=4u tile=400u\n.param Nbpr={tile/0.105u}\n.param Nseg={tile/PnTSV}\n.param Rbpr={50*PnTSV/12/(Nbpr*Nseg)}
TEXT 728 120 Left 2 !.param NnTSV={(tile/PnTSV) * (tile/(2*0.105u))}\n.param RnTSV={2/NnTSV}
TEXT 728 176 Left 2 !.param Lbsm1={2*PnTSV}\n.param RsegBSM1={80m*Lbsm1/0.5u}\n.param NsegBSM1={(tile/PnTSV) * (tile/(2*PnTSV))}\n.param Rbsm1={RsegBSM1/12/NsegBSM1}
TEXT 728 288 Left 2 !.param RtapOne={0.5*(2u/PnTSV)**2}\n.param Ntap={(tile/(2*PnTSV))**2}\n.param Rtap={RtapOne/Ntap}
TEXT 1360 8 Left 2 !.param Pb=57u\n.param Nbump={(tile/Pb)**2}\n.param Rbsm3={40m / 4 / Nbump}
TEXT 1360 88 Left 2 !.param Rbump={10m/Nbump}
TEXT 1368 168 Left 2 !.param alpha=3\n.param wBus={Pb*(alpha+1)/alpha}\n.param Pp=150u\n.param Nbus={tile/Pp}\n.param Rrdl3={2m*tile/wBus/3/Nbus}
TEXT 1880 8 Left 2 !.param hVia=10u\n.param Dvia=50u\n.param RviaOne={1.68e-8 * hVia / (3.14159 * (Dvia/2)**2)}\n.param Rvia={RviaOne/Nbump}
TEXT 1880 152 Left 2 !.param Npillar={(tile/Pp)**2}\n.param Rrdl2={2m * 0.25 / Npillar}
TEXT 1888 208 Left 2 !.param Rrdl1={2m * 0.25 / Npillar}
TEXT 1896 288 Left 2 !.param RpillarOne={1.68e-8 * 120u / (3.14159 * (75u/2)**2)}\n.param Rpillar={RpillarOne/Npillar}
TEXT 744 -136 Left 2 !.step param PnTSV list 2u 4u 8u 16u
TEXT 1032 560 Left 2 !.param Rlat={40m}                          \n.param Rsup={(Rpillar+Rrdl1+2*Rvia+Rrdl2+Rrdl3+Rbump)*4}\n.param Rvia_cell={Rtap*16}
