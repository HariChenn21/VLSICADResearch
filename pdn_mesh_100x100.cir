* 100x100 Two-Layer Backside PDN Model
* Total cells: 10000   Total pads: 4
* Pad locations (first 8): (1,1), (1,100), (100,1), (100,100)
* Interface: 'Vout' (driven by Vsupply at 0.6 V)

*=========== Design Parameters ===========
.param Iload=1.543 PnTSV=4u tile=400u
.param Vout_dc=0.6
.param Pb=57u alpha=3 Pp=150u
.param hVia=10u Dvia=50u

*=========== Per-Layer Resistance ===========
.param Nbpr={tile/0.105u}
.param Nseg={tile/PnTSV}
.param Rbpr={50*PnTSV/12/(Nbpr*Nseg)}
.param NnTSV={(tile/PnTSV)*(tile/(2*0.105u))}
.param RnTSV={2/NnTSV}
.param Lbsm1={2*PnTSV}
.param RsegBSM1={80m*Lbsm1/0.5u}
.param NsegBSM1={(tile/PnTSV)*(tile/(2*PnTSV))}
.param Rbsm1={RsegBSM1/12/NsegBSM1}
.param RtapOne={0.5*(2u/PnTSV)**2}
.param Ntap={(tile/(2*PnTSV))**2}
.param Rtap={RtapOne/Ntap}
.param Nbump={(tile/Pb)**2}
.param Rbsm3={40m/4/Nbump}
.param Rbump={10m/Nbump}
.param wBus={Pb*(alpha+1)/alpha}
.param Nbus={tile/Pp}
.param Rrdl3={2m*tile/wBus/3/Nbus}
.param RviaOne={1.68e-8*hVia/(3.14159*(Dvia/2)**2)}
.param Rvia={RviaOne/Nbump}
.param Npillar={(tile/Pp)**2}
.param Rrdl2={2m*0.25/Npillar}
.param Rrdl1={2m*0.25/Npillar}
.param RpillarOne={1.68e-8*120u/(3.14159*(75u/2)**2)}
.param Rpillar={RpillarOne/Npillar}

*=========== Mesh Aggregate (100x100, 4 pads) ===========
.param Ncells=10000
.param Rlat=40m
.param Rsup={(Rpillar+Rrdl1+2*Rvia+Rrdl2+Rrdl3+Rbump)*4}
.param Rvia_cell={Rtap*Ncells}

*=========== Upper Layer Horizontal Laterals ===========
